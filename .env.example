DATABASE_URL="file:./saferef.db"

# Session signing (32+ random bytes)
SESSION_SECRET="change-me-to-a-random-string"

# Role passwords (bcrypt hashes)
# Generate with: node scripts/hash-password.mjs <password>
# IMPORTANT: escape every $ as \$ — Next.js @next/env expands $VAR references.
# Example: a hash "$2b$10$abc..." must be written as "\$2b\$10\$abc..."
ADMIN_PASSWORD_HASH=""
SALES_PASSWORD_HASH=""
MANAGEMENT_PASSWORD_HASH=""
