generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model RefrigerantV5 {
  id                String  @id
  name              String
  safetyClass       String
  toxicityClass     String
  flammabilityClass String
  atelOdl           Float?
  lfl               Float?
  practicalLimit    Float
  vapourDensity     Float
  molecularMass     Float
  boilingPoint      String?
  gwp               String?
  gasGroup          String
}

model GasCategory {
  id          String @id
  nameFr      String
  nameEn      String
  code        String
  safetyClass String
  coverage    Int    @default(50)
  density     String
  specs       String @default("{}")
}

model Application {
  id                String  @id           // "supermarket", "machinery_room"
  labelFr           String
  labelEn           String
  icon              String  @default("🏢")
  descFr            String  @default("")
  descEn            String  @default("")
  // M1 regulatory defaults
  accessCategory    String  @default("b")  // "a","b","c"
  locationClass     String  @default("II") // "I","II","III","IV"
  belowGround       Boolean @default(false)
  isMachineryRoom   Boolean @default(false)
  isOccupiedSpace   Boolean @default(false)
  humanComfort      Boolean @default(false)
  c3Applicable      Boolean @default(false)
  mechVentilation   Boolean @default(false)
  // M2 selection defaults
  productFamilies   String  @default("[]")  // JSON: ["MIDI","MP"]
  defaultRanges     String  @default("{}")  // JSON: {"R744":"0-10000ppm"}
  suggestedGases    String  @default("[]")  // JSON: ["co2","hfc1"]
  applicableSpaceTypes String @default("[]") // JSON array of space type IDs
  sortOrder         Int     @default(0)
}

model SpaceType {
  id                String  @id           // "sales_area", "cold_room", "machinery_room"
  labelFr           String
  labelEn           String
  icon              String  @default("🏢")
  // Regulatory defaults
  accessCategory    String  @default("b")
  locationClass     String  @default("II")
  belowGround       Boolean @default(false)
  isMachineryRoom   Boolean @default(false)
  isOccupiedSpace   Boolean @default(false)
  humanComfort      Boolean @default(false)
  c3Applicable      Boolean @default(false)
  mechVentilation   Boolean @default(false)
  sortOrder         Int     @default(0)
}

model AdminUser {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String?
  role     String  @default("admin")
}

model CalcSheet {
  id          String   @id @default(cuid())
  ref         String   @unique
  clientJson  String   @default("{}")   // JSON: client info
  gasAppJson  String   @default("{}")   // JSON: gas + application selection
  zonesJson   String   @default("[]")   // JSON: array of zones with dimensions
  resultJson  String   @default("{}")   // JSON: M1 calculation results
  regulation  String   @default("en378") // "en378", "ashrae15", "iso5149"
  createdAt   DateTime @default(now())
  status      String   @default("draft") // "draft", "complete", "archived"
}

// ── Product Catalog (migrated from DetectBuilder) ─────────────────────

model Product {
  id           String   @id @default(cuid())
  type         String                        // "detector", "sensor", "controller", "alert", "accessory"
  family       String                        // "MIDI", "X5", "RM", "Aquis", "Controller", "Accessory"
  name         String
  code         String   @unique
  price        Float    @default(0)
  image        String?
  specs        String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tier         String   @default("standard")
  productGroup String   @default("A")
  gas          String   @default("[]")       // JSON: ["CO2","HFC1","HFC2","NH3","R290"]
  refs         String   @default("[]")       // JSON: ["R744","R32","R717"]
  range        String?
  sensorTech   String?
  sensorLife   String?
  power        Float?
  voltage      String?
  ip           String?
  tempMin      Float?
  tempMax      Float?
  relay        Int      @default(0)
  analog       String?
  modbus       Boolean  @default(false)
  standalone   Boolean  @default(true)
  atex         Boolean  @default(false)
  mount        String   @default("[]")       // JSON: ["wall","ceiling","floor"]
  remote       Boolean  @default(false)
  features     String?
  connectTo    String?
  discontinued Boolean  @default(false)
  channels     Int?
  maxPower     Float?
  powerDesc    String?
  relaySpec    String?
  analogType   String?
  modbusType   String?
  subCategory        String?                 // "alert", "service", "mounting", "power", "spare"
  compatibleFamilies String  @default("[]")  // JSON: ["MIDI","X5"] or ["ALL"]

  // ─── V2 fields ───
  variant         String?
  subType         String?
  function        String?
  status          String   @default("active")
  ports           String   @default("[]")
  connectionRules String   @default("{}")
  compatibleWith  String   @default("[]")
}

model DiscountMatrix {
  id            String @id @default(cuid())
  customerGroup String
  productGroup  String
  discountPct   Float
}

model Quote {
  id            String   @id @default(cuid())
  ref           String   @unique
  status        String   @default("draft")    // "draft","sent","accepted","rejected"
  // Client
  clientName    String   @default("")
  clientEmail   String   @default("")
  clientCompany String   @default("")
  clientPhone   String   @default("")
  // Project
  projectName   String   @default("")
  projectRef    String   @default("")
  // Content
  bomJson       String   @default("[]")       // JSON: BOMLine[] — all lines with qty, prices
  zonesJson     String   @default("[]")       // JSON: zone summaries
  configJson    String   @default("{}")       // JSON: SelectorInput or gas/app context
  // Pricing
  totalGross    Float    @default(0)
  totalNet      Float    @default(0)
  customerGroup String   @default("")
  currency      String   @default("EUR")
  // Regulation (if from Designer)
  regulation    String?
  calcSheetRef  String?                        // link to CalcSheet.ref if generated from Designer
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  expiresAt     DateTime?
}

model LoginLog {
  id        String   @id @default(cuid())
  role      String
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

model Lead {
  id              String   @id @default(cuid())
  source          String   @default("calculator")
  currentStep     Int      @default(1)
  status          String   @default("in_progress")
  firstName       String   @default("")
  lastName        String   @default("")
  company         String   @default("")
  email           String   @default("")
  phone           String   @default("")
  country         String   @default("")
  clientType      String   @default("")
  application     String   @default("")
  refrigerant     String   @default("")
  preferredFamily String   @default("")
  voltage         String   @default("")
  atex            Boolean  @default(false)
  mountingType    String   @default("")
  regulation      String   @default("")
  customerGroup   String   @default("")
  zonesJson       String   @default("[]")
  totalDetectors  Int      @default(0)
  resultJson      String   @default("{}")
  quoteId         String?
  quoteRef        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

